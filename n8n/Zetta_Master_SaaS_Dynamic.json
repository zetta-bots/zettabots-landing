    {
      "parameters": {
        "jsCode": "let history = [];\nlet systemPrompt = 'Você é o Zetta, assistente virtual inteligente da ZettaBots. Seja cordial e direto.';\n\nconst mainData = $(\"Buscar Prompt do Cliente\").first().json;\nconst phone = mainData.senderPhone || \"000\";\nconst instanceName = mainData.instanceName || 'ZettaBots';\nconst currentText = mainData.messageText || \"Oi\";\n\n// Puxa a memória\ntry {\n  const res = $('Buscar Memoria').first().json;\n  const val = Array.isArray(res) ? res[0]?.value : res?.value;\n  if (val) history = JSON.parse(val);\n} catch(e) {}\n\n// Puxa o prompt customizado do cliente\ntry {\n  const resPrompt = $('Buscar Prompt do Cliente').first().json;\n  const customPrompt = Array.isArray(resPrompt) ? resPrompt[0]?.system_prompt : resPrompt?.system_prompt;\n  if (customPrompt && customPrompt.trim() !== '') {\n    systemPrompt = customPrompt;\n  }\n} catch(e) {}\n\n// Puxa o conhecimento extraído\nlet knowledge = '';\ntry {\n  const resKB = $('Buscar Conhecimento').first().json;\n  if (Array.isArray(resKB)) {\n    knowledge = resKB.map(item => item.extracted_text).filter(t => t).join('\\n---\\n');\n  } else if (resKB?.extracted_text) {\n    knowledge = resKB.extracted_text;\n  }\n} catch(e) {}\n\nif (knowledge && knowledge.trim() !== '') {\n  systemPrompt += '\\n\\nBASE DE CONHECIMENTO CRÍTICA (Use estes dados para responder):\\n' + knowledge;\n}\n\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...history,\n  { role: 'user', content: currentText }\n].filter(m => m.content).slice(-15);\n\nreturn [{ json: { messages, history, currentText, senderPhone: phone, instanceName } }];"
      },
