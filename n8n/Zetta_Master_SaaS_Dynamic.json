    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst data = body.data || $json.data;\nif (!data || !data.key) return [];\n\n// 1. Ignorar mensagens enviadas pelo próprio bot\nif (data.key.fromMe === true) return [];\n\n// 2. Ignorar Grupos do WhatsApp automaticamente\nif (data.key.remoteJid.includes('@g.us')) {\n  console.log('Ignorando grupo:', data.key.remoteJid);\n  return [];\n}\n\n// 3. Ignorar números de sistema (Loop infinito)\nconst systemNumbers = ['5511977737283', '5521968755222'];\nconst senderPhone = data.key.remoteJid.split('@')[0].replace(/\\D/g, '');\nif (systemNumbers.includes(senderPhone)) return [];\n\nconst text = data.message?.conversation || data.message?.extendedTextMessage?.text || data.message?.imageMessage?.caption || '';\nconst isAudio = !!data.message?.audioMessage;\nconst messageId = data.key.id;\n\nif (!text.trim() && !isAudio) return [];\n\n// Pega o nome da instância que recebeu a mensagem\nconst instanceName = body.instance || 'ZettaBots';\n\nreturn [{ json: { senderPhone, messageText: text, isAudio, messageId, pushName: data.pushName || 'Cliente', instanceName } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1504,
        64
      ],
      "id": "e0ded412-937e-4d62-941d-9cc2da73218b",
