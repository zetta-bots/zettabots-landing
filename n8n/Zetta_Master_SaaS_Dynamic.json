      "parameters": {
        "jsCode": "let result = { sentiment: 'neutral', notes: 'Contato inicial', stage: 'lead' };\n\ntry {\n  const content = $json.choices[0].message.content;\n  const parsed = JSON.parse(content);\n  result.sentiment = parsed.sentiment || 'neutral';\n  result.notes = parsed.notes || 'Sem notas';\n  result.stage = parsed.stage || 'lead';\n} catch (e) {\n  console.error('Erro ao processar IA:', e);\n}\n\nreturn [{ json: result }];"
      },
