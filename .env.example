# ZettaBots Landing Page Configuration

# WhatsApp Contact Number (format: country code + number, no spaces/hyphens)
VITE_WHATSAPP_NUMBER=5521969875522

# Formspree Form ID (get from https://formspree.io)
# Example: f/xvzdkvra
VITE_FORMSPREE_ID=f/xvzdkvra

# Google Analytics Tracking ID (optional)
# Example: G-XXXXXXXXXX
VITE_GA_ID=

# reCAPTCHA v3 Site Key (get from https://www.google.com/recaptcha/admin)
# Optional - for spam protection on contact form
VITE_RECAPTCHA_SITE_KEY=

# Deployment Environment
# Values: development, staging, production
VITE_ENV=development

# Backend Variables (Brevo & N8N)
BREVO_API_KEY=
BREVO_LIST_ID=2
NOTIFY_EMAIL=seu-email@exemplo.com
N8N_WEBHOOK_URL=
